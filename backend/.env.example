# GlazeUp Backend Environment Variables

# Server
PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Square OAuth
SQUARE_APPLICATION_ID=sq0atp-XXXXX
SQUARE_APPLICATION_SECRET=sq0csp-XXXXX
SQUARE_ACCESS_TOKEN=sq0atp-XXXXX  # Or leave empty to use OAuth flow
SQUARE_ENVIRONMENT=production  # or 'sandbox' for testing

# Stripe
STRIPE_PUBLIC_KEY=pk_live_XXXXX  # or pk_test_
STRIPE_SECRET_KEY=sk_live_XXXXX  # or sk_test_
STRIPE_WEBHOOK_SECRET=whsec_XXXXX

# Stripe Price IDs (create these in Stripe dashboard)
STRIPE_PRICE_STARTER=price_XXXXX    # £29/month
STRIPE_PRICE_PRO=price_XXXXX        # £59/month
STRIPE_PRICE_ENTERPRISE=price_XXXXX # Custom

# URLs
API_URL=http://localhost:3001  # or your deployed backend URL
FRONTEND_URL=http://localhost:3000  # or your deployed frontend URL

# Logging
LOG_LEVEL=debug
