# ═══════════════════════════════════════════════════════════════
# GlazeUp Backend Configuration
# Copy this to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════

# ── Supabase ──
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGci...
SUPABASE_SERVICE_KEY=eyJhbGci...  # Service role key for backend

# ── Square ──
SQUARE_CLIENT_ID=sq0atp...
SQUARE_CLIENT_SECRET=sq0csp...
SQUARE_ENVIRONMENT=production  # or 'sandbox' for testing
SQUARE_API_VERSION=2024-07-17  # Latest Square API version

# ── Stripe ──
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Stripe Product IDs (set these up in Stripe dashboard first) ──
STRIPE_PRICE_STARTER=price_...     # Monthly, £29 or equivalent
STRIPE_PRICE_PROFESSIONAL=price_... # Monthly, £49
STRIPE_PRICE_ENTERPRISE=price_...   # Monthly, £79 or custom

# ── Server ──
PORT=3000
NODE_ENV=production
API_URL=https://glazeup.app  # Your domain

# ── Webhooks ──
SQUARE_WEBHOOK_URL=https://glazeup.app/api/webhooks/square
STRIPE_WEBHOOK_URL=https://glazeup.app/api/webhooks/stripe

# ── Sync Job (for scheduled tasks) ──
SYNC_INTERVAL_MINUTES=60  # How often to pull Square data
